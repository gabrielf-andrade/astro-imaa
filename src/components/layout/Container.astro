---
import { cn } from "@/lib/utils/ui-utils";

interface Props {
  size?: "sm" | "md" | "lg" | "xl";
  class?: string;
}

const sizeMap = {
  sm: "max-w-2xl",
  md: "max-w-3xl",
  lg: "max-w-5xl",
  xl: "max-w-7xl",
} as const;

const { size = "lg", class: className } = Astro.props;
---

<div class={cn("container mx-auto px-4", sizeMap[size], className)}>
  <slot />
</div>
