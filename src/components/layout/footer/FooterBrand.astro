---
import SanityImage from "@/components/common/SanityImage";
import SocialLinks from "@/components/common/SocialLinks";
import { CARNIVAL_BLOCK_NAME, INSTITUTE_NAME } from "@/lib/constants";
import type { QuerySocialLink, SanityImageBase } from "@/lib/sanity-derived-types";

interface Props {
  logo?: SanityImageBase | null;
  description?: string | null;
  socialLinks: QuerySocialLink[];
}

const { logo, description, socialLinks } = Astro.props;
---

<div>
  <a href="/" class="flex items-center gap-3 mb-4 w-fit">
    {
      logo && (
        <SanityImage
          client:visible
          image={logo}
          width={48}
          height={48}
          className="w-12 h-12 rounded-full object-cover"
        />
      )
    }
    <div>
      <p class="text-xs font-semibold text-secondary uppercase font-sans">{INSTITUTE_NAME}</p>
      <p class="text-xl font-bold text-white font-serif">{CARNIVAL_BLOCK_NAME}</p>
    </div>
  </a>

  {
    description && (
      <p class="text-sm text-primary-foreground/80 leading-relaxed font-sans max-w-sm mb-6">{description}</p>
    )
  }

  <SocialLinks
    client:visible
    socialLinks={socialLinks}
    className="gap-3"
    iconClassName="w-5 h-5 text-white"
    linkClassName="size-10"
  />
</div>
