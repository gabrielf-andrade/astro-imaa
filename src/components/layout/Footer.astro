---
import blocoLogo from "@/assets/bloco.jpg";
import SocialLinks from "@/components/common/SocialLinks";
import WhatsAppIcon from "@/components/icons/WhatsAppIcon";
import { DEFAULT_TITLE } from "@/lib/constants";
import type { QueryContactInfo, QueryMenuItem, QuerySocialLink } from "@/lib/sanity-derived-types";
import { buildUrlFromSlug } from "@/lib/utils/string-utils";
import { Image } from "astro:assets";
import { getEntry } from "astro:content";
import { Mail, MapPin, Phone } from "lucide-react";

const siteSettings = await getEntry("siteSettings", "site-settings");

const title = siteSettings?.data.title || DEFAULT_TITLE;
const footerMenu = siteSettings?.data.footerMenu || { label: "", items: [] };
const menuItems: QueryMenuItem[] = (footerMenu.items ?? []).map((item) => ({
  ...item,
  submenu: item.submenu ?? null,
}));

const socialLinks = (siteSettings?.data.socialLinks ?? []) as QuerySocialLink[];
const contactInfo = siteSettings?.data.contactInfo as QueryContactInfo | null;

const currentYear = new Date().getFullYear();
---

<footer class="bg-primary-dark text-primary-foreground">
  <div class="h-1 w-full bg-linear-to-r from-primary via-secondary via-50% to-accent"></div>

  <div class="container mx-auto px-4 max-w-7xl py-14">
    <div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-4 gap-10">
      {/* Logo e descrição */}
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center gap-3 mb-4 w-fit">
          <Image
            src={blocoLogo}
            width={48}
            height={48}
            class="w-12 h-12 rounded-full object-cover"
            alt="Logo Instituto Mestre Abiud"
          />
          <div>
            <p class="text-xs font-semibold text-secondary uppercase tracking-wide font-sans">Instituto Mestre</p>
            <p class="text-xl font-bold text-white font-serif leading-tight">Abiud Almeida</p>
          </div>
        </a>

        {
          siteSettings?.data.description && (
            <p class="text-sm text-primary-foreground/80 leading-relaxed font-sans max-w-sm mb-6">
              {siteSettings.data.description}
            </p>
          )
        }

        <SocialLinks
          client:visible
          socialLinks={socialLinks}
          className="gap-3"
          iconClassName="w-5 h-5 text-white"
          linkClassName="size-10"
        />
      </div>

      {/* Links de navegação */}
      {
        menuItems.length > 0 && (
          <div>
            <h3 class="text-sm font-bold uppercase tracking-widest text-secondary mb-4 font-sans">
              {footerMenu.label || "Navegação"}
            </h3>
            <ul class="space-y-2">
              {menuItems.map((link) => (
                <li>
                  <a
                    href={buildUrlFromSlug(link.slug)}
                    class="text-sm text-primary-foreground/80 hover:text-secondary transition-colors font-sans"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }

      {/* Contato */}
      {
        contactInfo && (
          <div>
            <h3 class="text-sm font-bold uppercase tracking-widest text-secondary mb-4 font-sans">Contato</h3>
            <ul class="space-y-3">
              {contactInfo.address && (
                <li class="flex items-start gap-2">
                  <MapPin className="w-4 h-4 text-secondary mt-0.5 shrink-0" />
                  <div class="text-sm text-primary-foreground/80 font-sans">
                    {contactInfo.address.street && (
                      <p>
                        {contactInfo.address.street}
                        {contactInfo.address.complement && `, ${contactInfo.address.complement}`}
                      </p>
                    )}
                    {contactInfo.address.neighborhood && (
                      <p>
                        {contactInfo.address.neighborhood} -{" "}
                        {contactInfo.address.cityState && `${contactInfo.address.cityState}`}
                      </p>
                    )}
                    {contactInfo.address.zipCode && (
                      <p class="text-primary-foreground/60">{contactInfo.address.zipCode}</p>
                    )}
                  </div>
                </li>
              )}
              {contactInfo.emails
                ?.filter((item) => item.address)
                .map((item) => (
                  <li class="flex items-center gap-2">
                    <Mail className="w-4 h-4 text-secondary shrink-0" />
                    <a
                      href={`mailto:${item.address}`}
                      class="text-sm text-primary-foreground/80 hover:text-secondary transition-colors font-sans"
                    >
                      {item.address}
                    </a>
                  </li>
                ))}
              {contactInfo.phones
                ?.filter((item) => item.number)
                .map((item) => (
                  <li class="flex items-center gap-2">
                    {item.isWhatsApp ? (
                      <WhatsAppIcon className="w-5 h-5 text-secondary shrink-0" />
                    ) : (
                      <Phone className="w-5 h-5 text-secondary shrink-0" />
                    )}
                    <a
                      href={item.isWhatsApp ? `https://wa.me/${item.number?.replace(/\D/g, "")}` : `tel:${item.number}`}
                      target={item.isWhatsApp ? "_blank" : undefined}
                      rel={item.isWhatsApp ? "noopener noreferrer" : undefined}
                      class="text-sm text-primary-foreground/80 hover:text-secondary transition-colors font-sans"
                    >
                      {item.number}
                    </a>
                  </li>
                ))}
            </ul>
          </div>
        )
      }
    </div>
  </div>

  {/* Bottom bar */}
  <div class="border-t border-white/10">
    <div
      class="container mx-auto px-4 max-w-7xl py-5 flex flex-col sm:flex-row items-center justify-end divide-x divide-border/50"
    >
      <p class="text-xs text-primary-foreground/60 font-sans text-center sm:text-left px-2">
        © <span id="footer-year">{currentYear}</span>
        {title} - Todos os direitos reservados.
      </p>

      <a
        href="/politica-de-privacidade"
        class="px-2 text-xs text-primary-foreground/60 hover:text-secondary transition-colors font-sans underline underline-offset-2"
      >
        Política de Privacidade
      </a>
    </div>
  </div>
</footer>

<script>
  const footerYear = document.getElementById("footer-year");
  if (footerYear) {
    footerYear.textContent = new Date().getFullYear().toString();
  }
</script>
