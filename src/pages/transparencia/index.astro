---
import PortableTextRenderer from "@/components/common/PortableTextRenderer.astro";
import TransparencySectionCard from "@/components/features/transparency/TransparencySectionCard.astro";
import Container from "@/components/layout/Container.astro";
import PageSection from "@/components/layout/PageSection.astro";
import PageHero from "@/components/sections/PageHero.astro";
import Layout from "@/layouts/Layout.astro";
import { loadQuery } from "@/lib/load-query";
import { ALL_TRANSPARENCY_SECTIONS_QUERY, TRANSPARENCY_INDEX_PAGE_QUERY } from "@/lib/queries/transparency";
import type { ALL_TRANSPARENCY_SECTIONS_QUERY_RESULT, TRANSPARENCY_INDEX_PAGE_QUERY_RESULT } from "@/lib/sanity.types";
import { truncateExcerpt } from "@/lib/utils/string-utils";
import { ExternalLink } from "lucide-react";

const [{ data: page }, { data: sections }] = await Promise.all([
  loadQuery<TRANSPARENCY_INDEX_PAGE_QUERY_RESULT>({ query: TRANSPARENCY_INDEX_PAGE_QUERY }),
  loadQuery<ALL_TRANSPARENCY_SECTIONS_QUERY_RESULT>({ query: ALL_TRANSPARENCY_SECTIONS_QUERY }),
]);

const validSections = (sections ?? []).filter((s) => s.slug);
---

<Layout
  title={page?.title ?? "Portal da Transparência"}
  description={truncateExcerpt(page?.excerpt ?? page?.autoExcerpt)}
  image={page?.featuredImage}
>
  <PageHero heading={page?.hero?.heading ?? "Portal da Transparência"} tagline={page?.hero?.tagline} />

  {
    page?.content && (
      <PageSection bg="muted" py="md">
        <Container size="md">
          <PortableTextRenderer value={page.content} class="prose-p:text-muted-foreground" />
        </Container>
      </PageSection>
    )
  }

  <PageSection py="md">
    <Container size="lg">
      {
        validSections.length > 0 ? (
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            {validSections.map((section) => (
              <TransparencySectionCard section={section} />
            ))}
          </div>
        ) : (
          <p class="text-center text-muted-foreground font-sans">Nenhuma seção cadastrada ainda.</p>
        )
      }

      <div class="mt-12 text-center">
        <a
          href="https://portaldatransparencia.gov.br"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 border border-primary text-primary hover:bg-primary hover:text-white font-sans text-sm font-medium px-6 py-2.5 rounded-md transition-colors"
        >
          Portal da Transparência do Governo Federal
          <ExternalLink className="w-4 h-4" />
        </a>
      </div>
    </Container>
  </PageSection>
</Layout>
